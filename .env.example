# ===========================================================================
# KLKCHAN API — Variables de entorno
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas .env al repositorio.
# ===========================================================================

# ---------------------------------------------------------------------------
# Seguridad JWT  (REQUERIDO)
# ---------------------------------------------------------------------------

# Clave secreta para firmar tokens JWT.
# Genera una con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=f3d6691b09f1aea2824ac34674bc0d8f21ef09962322ecd46eee1a1182abbe5e

# Algoritmo de firma (no cambiar salvo que sepas lo que haces)
ALGORITHM=HS256

# Duración del access token en minutos
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Duración del refresh token en días
REFRESH_TOKEN_EXPIRE_DAYS=7

# Issuer incluido en el JWT (campo "iss")
JWT_ISS=klkchan

# ---------------------------------------------------------------------------
# Entorno de ejecución
# ---------------------------------------------------------------------------

# Valores válidos: development | production
# En "production": /docs y /redoc quedan desactivados.
# En "development": CORS permite localhost:3000/5173/8080 automáticamente.
ENVIRONMENT=development

# ---------------------------------------------------------------------------
# CORS  (solo se lee cuando ENVIRONMENT != development)
# ---------------------------------------------------------------------------

# Orígenes permitidos separados por coma.
# Ejemplo: https://miapp.com,https://www.miapp.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ---------------------------------------------------------------------------
# Roles iniciales  (opcional)
# ---------------------------------------------------------------------------

# Emails que reciben rol "admin" al registrarse (separados por coma).
ADMIN_EMAILS=admin@example.com

# Emails que reciben rol "mod" al registrarse (separados por coma).
MOD_EMAILS=mod@example.com
